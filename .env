APP_NAME="HSE SaaS Platform"
APP_ENV=production
APP_KEY=base64:m3mtkr200TxX9nCEhbs6qjRwgV2b9SCdoHbNZg1/WzY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://webapp.local

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hse_saas
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=hse_cache_
CACHE_TTL_DASHBOARD=120
CACHE_TTL_LIST=90
CACHE_TTL_DETAIL=300

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@hse-saas.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=hse-saas-backups
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Encryption Keys (Generate with: php artisan key:generate-encryption)
ENCRYPTION_KEY_256=
ENCRYPTION_IV=

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_EXPIRATION=null

# Performance Settings
HORIZON_MEMORY_LIMIT=256
QUEUE_WORKERS=4
DB_POOL_SIZE=10

# Security Headers
SECURITY_HEADERS_HSTS=true
SECURITY_HEADERS_CSP=true
SECURITY_HEADERS_XFRAME=true
SECURITY_HEADERS_XSS=true

# Feature Flags
ENABLE_E2E_ENCRYPTION=true
ENABLE_AUDIT_LOG=true
ENABLE_REALTIME_NOTIFICATIONS=true
